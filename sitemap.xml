<?xml version="1.0" encoding="UTF-8"?><urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">{% assign pages = site.pages | where_exp: "p", "p.sitemap != false" %}{% for p in pages %}{% if p.url contains '.xml' or p.url contains '.txt' or p.url contains '.json' %}{% else %}<url><loc>{{ p.url | absolute_url }}</loc><changefreq>monthly</changefreq></url>{% endif %}{% endfor %}{% for p in site.products %}<url><loc>{{ p.url | absolute_url }}</loc><changefreq>monthly</changefreq></url>{% endfor %}{% for g in site.guides %}<url><loc>{{ g.url | absolute_url }}</loc><changefreq>monthly</changefreq></url>{% endfor %}</urlset>